# ====================================================================
# 1. System & OS Files
# ====================================================================
# Prevents operating system specific metadata from cluttering the repository
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ====================================================================
# 2. IDEs and Code Editors
# ====================================================================
# Ignores local workspace configurations for popular editors (IntelliJ, VS Code, Eclipse)
.idea/
.vscode/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/
.factorypath
bin/
out/

# ====================================================================
# 3. Java & Maven Backend (pos-backend, pos-core, invoice-app)
# ====================================================================
# Ignores all compiled binaries and build outputs generated by 'mvn clean install'
**/target/
**/*.class
**/*.jar
**/*.war
**/*.ear

# Crash logs and execution logs
*.log
**/logs/

# Refuse embedded maven wrapper binaries if not needed explicitly
.mvn/wrapper/maven-wrapper.jar

# ====================================================================
# 4. Node.js & Next.js Frontend (pos-frontend)
# ====================================================================
# Dependency directory - should never be checked in as it's built per machine via npm install
**/node_modules/

# Next.js production build production output folder
**/.next/
**/out/

# Local environment files containing sensitive credentials, API keys, or database passwords
.env*.local

# Debug logs generated by package managers during failure states
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vercel deployment state configuration profiles
.vercel

# TypeScript incremental compilation cache
*.tsbuildinfo